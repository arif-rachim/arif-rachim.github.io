---
import Page from "./Page.astro";
const years = new Date().getFullYear() - 2004;

const skills = [
    "RAG", "LLMs", "MCP", "Vector DBs",
    "Neo4j", "ChromaDB", "Python", "Prompt Engineering",
    "React", "TypeScript", "Node.js", "Design Systems",
    "Astro", "Next.js", "Java", "TensorFlow",
    "Docker", "PWA",
];
---

<Page id="about" eyebrow="About">
    <div class="about">
        <div class="headline">
            <h2 class="title">
                <span class="accent">{years} years</span> of production software.
                Now leading AI, data, and platform work where off-the-shelf tutorials don't apply.
            </h2>
        </div>
        <div class="body">
            <p class="description">
                I spent two decades building web platforms, design systems,
                and mobile apps. As Principal Application Developer I now lead
                AI, data, and platform work — end-to-end RAG, LLM tool
                orchestration, SQL and database optimization, custom
                frontends, and cross-team integration — inside air-gapped,
                regulated networks where most AI tooling isn't designed to
                run.
            </p>
            <p class="description">
                Research-first, prototype fast, iterate with the team. I drive
                architectural decisions end-to-end and mentor engineers on
                SQL, RAG, graph modeling, and tool design — while staying
                hands-on with the code that matters.
            </p>
            <div class="skills">
                {skills.map((s) => <span class="chip">{s}</span>)}
            </div>
        </div>
    </div>
</Page>

<style>
    .about {
        display: grid;
        grid-template-columns: 1fr 1.25fr;
        gap: clamp(2rem, 5vw, 4.5rem);
        align-items: start;
    }

    .title {
        font-size: var(--fs-2xl);
        font-weight: 600;
        line-height: 1.1;
        letter-spacing: -0.025em;
    }

    .accent {
        color: var(--accent);
    }

    .body {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
    }

    .description {
        font-size: var(--fs-base);
        color: var(--muted);
        line-height: 1.7;
    }

    .skills {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-top: 0.75rem;
    }

    .chip {
        padding: 0.4rem 0.9rem;
        background: var(--bg-elev);
        border: 1px solid var(--border);
        border-radius: 999px;
        font-size: var(--fs-xs);
        font-weight: 500;
        color: var(--ink-2);
        transition: transform 0.2s ease, border-color 0.2s ease;
    }

    .chip:hover {
        border-color: var(--accent);
        transform: translateY(-2px);
    }

    @media (max-width: 820px) {
        .about {
            grid-template-columns: 1fr;
        }
    }
</style>
