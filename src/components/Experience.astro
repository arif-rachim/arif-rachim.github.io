---
import Page from "./Page.astro";

type Role = {
    title: string;
    company: string;
    period: string;
    summary?: string;
    bullets: string[];
};

const roles: Role[] = [
    {
        title: "Principal Application Developer · AI & Platform",
        company: "AI Department",
        period: "Nov 2025 — Present",
        summary:
            "Leading AI systems, data engineering, and platform work across the AI department — from end-to-end RAG and LLM tooling to SQL optimization, custom frontends, cross-team integration, and mentoring.",
        bullets: [
            "Designed and shipped end-to-end Retrieval-Augmented Generation (RAG) pipelines over a 500GB+ multilingual technical documentation corpus — Arabic/English ingestion, ChromaDB vector storage, and Sentence Transformer embeddings.",
            "Built and deployed Model Context Protocol (MCP) tools that let an internal LLM platform reason over crew readiness, aircraft configuration, and safety documentation — refactoring multi-query joins into optimized database views and significantly reducing latency.",
            "Led a proof-of-concept custom chat UI to unlock MCP server elicitation (interactive user feedback during tool execution) where off-the-shelf OpenWebUI fell short.",
            "Tuned LLM parameters (temperature, context window) and iterated on system prompts with stakeholders — measurably improving response consistency and tool-chaining accuracy.",
            "Researched and piloted next-generation RAG techniques including RAPTOR (recursive tree-organized retrieval) and Knowledge-Graph RAG, proposing an incremental roadmap that preserves existing investment.",
            "Debugged and resolved a token-starvation issue that degraded Arabic document retrieval — tracing the root cause across embeddings, context window, and tool-call loops.",
            "Mentored junior engineers on MCP tool design, SQL query optimization, and RAG fundamentals.",
            "Deployed AI systems inside an air-gapped, security-restricted intranet — coordinating with infrastructure, database, and integration teams across UAT and production environments.",
            "Earned the Neo4j Professional Certification and began applying graph modeling to predictive logistics scenarios such as part-cycle tracking and aircraft serviceability.",
        ],
    },
    {
        title: "Front End Architect / Fullstack Engineer",
        company: "Global Aerospace Logistics, LLC",
        period: "2009 — 2025",
        summary:
            "Component design systems, dashboards, offline-first mobile apps, and backend file-view services for enterprise aerospace operations.",
        bullets: [
            "Utilized the React framework to methodically plan, design, and construct design system components for an enterprise resource planning (ERP) application — a suite of 50+ precisely built components including DataGrid, DataLookup, DropDown, Slide Panel, and the application Shell.",
            "Crafted UI components for dynamic dashboards (e.g. Operation Dashboard) — integrating interactive charts and tabular data, enhanced with fluid animations and a polished interface.",
            "Designed, developed, and deployed a mobile application with seamless offline functionality for aircraft pilots and technicians to record mission info, flight hours, faults, and scheduled inspections — syncing with the central ERP using advanced encryption.",
            "Built a Geographical Information System using open-source Apache Flex (Adobe Flex) to mark the location of aircraft as they are deployed — known internally as Fleet Location.",
            "Created a server health check monitoring system using socket technology for continuous real-time data updates — disk consumption, CPU utilization, and memory usage with 24/7 availability.",
            `Developed robust "File View" backend systems converting Excel, Word, and PowerPoint to PDF then SWF — enabling viewing without direct file downloads and protecting system security.`,
            "Built a client-centric reporting mechanism with React, encapsulated as a reusable component — expediting report development and freeing it from legacy Reporting Engine Server dependencies.",
            "Developed a complex Scheduler component to render aircraft mission schedules (Weekly Mission) — drawing schedule blocks accurately in a columnar structure with high-performance rendering.",
            "Actively assisted colleagues in implementing attractive UIs and recommended the right approaches for optimal front-end performance.",
        ],
    },
];
---

<Page id="experience" eyebrow="Experience">
    <div class="header-row">
        <h2 class="title">Relevant experience</h2>
        <p class="subtitle">
            Two decades of shipping software — from design systems and fullstack
            platforms to modern AI engineering.
        </p>
    </div>

    <div class="roles">
        {roles.map((role) => (
            <section class="role">
                <header class="role-head">
                    <div class="role-meta">
                        <span class="role-period">{role.period}</span>
                    </div>
                    <div class="role-title-wrap">
                        <h3 class="role-title">{role.title}</h3>
                        <div class="role-company">{role.company}</div>
                        {role.summary && <p class="role-summary">{role.summary}</p>}
                    </div>
                </header>
                <ol class="timeline">
                    {role.bullets.map((b, i) => (
                        <li class="item">
                            <div class="marker">
                                <span class="marker-dot"></span>
                                <span class="marker-line"></span>
                            </div>
                            <div class="card">
                                <div class="index">0{i + 1}</div>
                                <p class="text">{b}</p>
                            </div>
                        </li>
                    ))}
                </ol>
            </section>
        ))}
    </div>
</Page>

<style>
    .header-row {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        margin-bottom: clamp(2rem, 4vw, 3.5rem);
    }

    .title {
        font-size: var(--fs-2xl);
        font-weight: 600;
        letter-spacing: -0.025em;
        line-height: 1.1;
    }

    .subtitle {
        font-size: var(--fs-base);
        color: var(--muted);
        max-width: 60ch;
    }

    .roles {
        display: flex;
        flex-direction: column;
        gap: clamp(3rem, 5vw, 4.5rem);
    }

    .role-head {
        display: grid;
        grid-template-columns: 180px 1fr;
        gap: 1.5rem;
        align-items: start;
        margin-bottom: 1.75rem;
        padding-bottom: 1.25rem;
        border-bottom: 1px solid var(--border);
    }

    .role-meta {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .role-period {
        display: inline-flex;
        align-items: center;
        padding: 0.35rem 0.7rem;
        background: var(--bg-elev);
        border: 1px solid var(--border);
        border-radius: 999px;
        font-family: "JetBrains Mono", ui-monospace, monospace;
        font-size: 0.7rem;
        color: var(--ink-2);
        font-weight: 500;
        width: fit-content;
    }

    .role-title {
        font-size: var(--fs-lg);
        font-weight: 600;
        letter-spacing: -0.015em;
        line-height: 1.2;
    }

    .role-company {
        font-size: var(--fs-sm);
        color: var(--muted);
        font-weight: 500;
        margin-top: 0.2rem;
    }

    .role-summary {
        margin-top: 0.75rem;
        font-size: var(--fs-base);
        color: var(--muted);
        line-height: 1.6;
        max-width: 62ch;
    }

    .timeline {
        list-style: none;
        display: flex;
        flex-direction: column;
    }

    .item {
        display: grid;
        grid-template-columns: 32px 1fr;
        gap: 1rem;
    }

    .marker {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding-top: 1.5rem;
    }

    .marker-dot {
        width: 12px;
        height: 12px;
        border-radius: 50%;
        background: var(--bg);
        border: 2px solid var(--accent);
        box-shadow: 0 0 0 4px rgba(255, 91, 46, 0.12);
        flex-shrink: 0;
    }

    .marker-line {
        flex: 1;
        width: 2px;
        background: linear-gradient(to bottom, var(--border-strong), var(--border) 60%, transparent);
        margin-top: 0.5rem;
    }

    .item:last-child .marker-line {
        display: none;
    }

    .card {
        background: var(--bg-elev);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 1.25rem 1.5rem;
        margin-bottom: 1rem;
        box-shadow: var(--shadow-sm);
        transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
        position: relative;
    }

    .card:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow);
        border-color: var(--border-strong);
    }

    .index {
        font-family: "JetBrains Mono", ui-monospace, monospace;
        font-size: 0.7rem;
        color: var(--accent);
        letter-spacing: 0.08em;
        font-weight: 500;
        margin-bottom: 0.4rem;
    }

    .text {
        color: var(--muted);
        font-size: var(--fs-base);
        line-height: 1.65;
    }

    @media (max-width: 700px) {
        .role-head {
            grid-template-columns: 1fr;
            gap: 0.75rem;
        }
    }

    @media (max-width: 560px) {
        .item {
            grid-template-columns: 24px 1fr;
            gap: 0.75rem;
        }

        .card {
            padding: 1rem 1.1rem;
        }
    }
</style>
