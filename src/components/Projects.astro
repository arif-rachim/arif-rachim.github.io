---
import Page from "./Page.astro";

type Project = {
    name: string;
    tag: string;
    year: string;
    description: string;
    stack: string[];
    href?: string;
    external?: boolean;
    status?: "Live" | "In production" | "Case study";
    accent?: "live" | "internal" | "research";
};

const projects: Project[] = [
    {
        name: "Wezo.ae",
        tag: "Marketplace · B2C",
        year: "Live",
        description:
            "A vacation-rental marketplace for private villas and farmstays across the UAE — pool villas, beach houses, and farm getaways in Ras Al Khaimah and beyond. Instant booking, verified properties, bilingual experience. Designed and built end-to-end.",
        stack: ["Next.js", "React", "TypeScript", "Node.js"],
        href: "https://www.wezo.ae",
        status: "Live",
        accent: "live",
    },
    {
        name: "Multilingual RAG over Technical Documentation",
        tag: "AI · Production",
        year: "2025 — 2026",
        description:
            "End-to-end Retrieval-Augmented Generation pipeline over a 500GB+ bilingual (Arabic / English) technical documentation corpus. Docling ingestion, ChromaDB vector storage, multilingual sentence-transformer embeddings, deployed on a fully air-gapped intranet.",
        stack: ["Python", "ChromaDB", "Docling", "Sentence Transformers", "MCP"],
        status: "In production",
        accent: "internal",
    },
    {
        name: "Graph-Based Logistics Modeling",
        tag: "AI · Research",
        year: "2026",
        description:
            "Neo4j-based proof-of-concept applying graph data modeling to predictive logistics problems — part-cycle tracking, aircraft serviceability, and relationship-driven analytics. Earned Neo4j Professional Certification along the way.",
        stack: ["Neo4j", "Cypher", "Python"],
        status: "Case study",
        accent: "research",
    },
    {
        name: "HUSO Prep Platform",
        tag: "EdTech · Web",
        year: "2024 — 2025",
        description:
            "A 40-day study program platform for the Homeschoolers United Science Olympiad — lesson player, dashboard, progress tracking, and daily HTML-based study materials across Chemistry, Physics, Biology, and Earth Science.",
        stack: ["TypeScript", "HTML", "CSS"],
        href: "./huso/",
        status: "Live",
        accent: "live",
    },
    {
        name: "Stock Watch",
        tag: "Fintech · Web",
        year: "2024",
        description:
            "A sample stock tracking application built on the TC39 Signal Proposal and React — exploring fine-grained reactivity patterns at the language level.",
        stack: ["React", "TC39 Signals", "TypeScript"],
        href: "./stock-watch/",
        status: "Live",
        accent: "live",
    },
    {
        name: "Todo List",
        tag: "Utility · Web",
        year: "2024",
        description:
            "Minimal todo list demo — a sandbox for experimenting with modern state management, persistence, and UI primitives.",
        stack: ["TypeScript", "HTML", "CSS"],
        href: "./todo-list/",
        status: "Live",
        accent: "live",
    },
];
---

<Page id="projects" eyebrow="Selected work">
    <div class="header-row">
        <h2 class="title">Things I've shipped.</h2>
        <p class="subtitle">
            A mix of AI systems deployed in regulated environments and public
            web apps you can try right now.
        </p>
    </div>

    <div class="grid">
        {projects.map((p) => {
            const isLink = !!p.href;
            const isExternal = isLink && p.href!.startsWith("http");
            const Tag = isLink ? "a" : "article";
            return (
                <Tag
                    class:list={["card", `accent-${p.accent}`]}
                    href={p.href}
                    target={isExternal ? "_blank" : undefined}
                    rel={isExternal ? "noopener noreferrer" : undefined}
                >
                    <div class="card-top">
                        <span class="card-tag">{p.tag}</span>
                        {p.status && <span class="card-status">{p.status}</span>}
                    </div>
                    <h3 class="card-name">{p.name}</h3>
                    <p class="card-desc">{p.description}</p>
                    <div class="card-bottom">
                        <div class="stack">
                            {p.stack.map((s) => <span class="stack-item">{s}</span>)}
                        </div>
                        {isLink && (
                            <span class="card-link">
                                {isExternal ? "Visit" : "Open"} <span aria-hidden="true">↗</span>
                            </span>
                        )}
                    </div>
                </Tag>
            );
        })}
    </div>
</Page>

<style>
    .header-row {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        margin-bottom: clamp(2rem, 4vw, 3rem);
    }

    .title {
        font-size: var(--fs-2xl);
        font-weight: 600;
        letter-spacing: -0.025em;
        line-height: 1.1;
    }

    .subtitle {
        font-size: var(--fs-base);
        color: var(--muted);
        max-width: 60ch;
    }

    .grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 1rem;
    }

    .card {
        position: relative;
        display: flex;
        flex-direction: column;
        gap: 0.85rem;
        background: var(--bg-elev);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 1.5rem 1.5rem 1.35rem;
        text-decoration: none;
        color: inherit;
        overflow: hidden;
        transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
        min-height: 280px;
    }

    .card::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: var(--accent);
        opacity: 0;
        transition: opacity 0.25s ease;
    }

    .card:hover {
        transform: translateY(-3px);
        box-shadow: var(--shadow);
        border-color: var(--border-strong);
    }

    .card:hover::before {
        opacity: 1;
    }

    a.card {
        cursor: pointer;
    }

    .card-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.5rem;
    }

    .card-tag {
        font-family: "JetBrains Mono", ui-monospace, monospace;
        font-size: 0.68rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--muted);
    }

    .card-status {
        font-size: 0.65rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        padding: 0.25rem 0.55rem;
        border-radius: 999px;
        background: var(--surface);
        color: var(--ink-2);
    }

    .accent-live .card-status {
        background: rgba(34, 197, 94, 0.12);
        color: #16803f;
    }

    .accent-internal .card-status {
        background: rgba(255, 91, 46, 0.12);
        color: var(--accent);
    }

    .accent-research .card-status {
        background: rgba(59, 130, 246, 0.12);
        color: #1e4fb8;
    }

    .card-name {
        font-size: var(--fs-md);
        font-weight: 600;
        line-height: 1.25;
        letter-spacing: -0.015em;
    }

    .card-desc {
        font-size: var(--fs-sm);
        color: var(--muted);
        line-height: 1.6;
        flex: 1;
    }

    .card-bottom {
        display: flex;
        flex-direction: column;
        gap: 0.65rem;
        margin-top: 0.25rem;
    }

    .stack {
        display: flex;
        flex-wrap: wrap;
        gap: 0.35rem;
    }

    .stack-item {
        font-size: 0.68rem;
        font-weight: 500;
        padding: 0.22rem 0.5rem;
        background: var(--surface);
        color: var(--ink-2);
        border-radius: 6px;
    }

    .card-link {
        font-size: var(--fs-xs);
        font-weight: 600;
        color: var(--accent);
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
    }

    .card-year {
        position: absolute;
        top: 1.5rem;
        right: 1.5rem;
        font-family: "JetBrains Mono", ui-monospace, monospace;
        font-size: 0.65rem;
        color: var(--muted-2);
        display: none;
    }
</style>
