---
import Page from "./Page.astro";
---

<Page id="contact" eyebrow="Contact">
    <div class="cta">
        <div class="cta-head">
            <h2 class="title">Let's build something great together.</h2>
            <p class="subtitle">
                I'm open to interesting opportunities, collaborations, and
                conversations. Drop a line — I reply to every message.
            </p>
        </div>

        <div class="actions">
            <a href="mailto:a.arif.r@gmail.com" class="btn btn-primary">
                a.arif.r@gmail.com
                <span aria-hidden="true">→</span>
            </a>
            <a href="arif-rachim-cv.pdf" class="btn btn-ghost" aria-label="Download CV as PDF">
                Download CV
                <span aria-hidden="true">↓</span>
            </a>
        </div>

        <div class="info-grid">
            <div class="info">
                <span class="label">Email</span>
                <span class="value">a.arif.r@gmail.com</span>
            </div>
            <div class="info">
                <span class="label">Phone</span>
                <span class="value">+971 50 901 8075</span>
            </div>
            <div class="info">
                <span class="label">Location</span>
                <span class="value">Dubai, UAE</span>
            </div>
            <div class="info">
                <span class="label">LinkedIn</span>
                <a class="value link" href="https://ae.linkedin.com/in/arifrachim" target="_blank" rel="me noopener noreferrer">
                    /in/arifrachim ↗
                </a>
            </div>
            <div class="info">
                <span class="label">GitHub</span>
                <a class="value link" href="https://github.com/arif-rachim" target="_blank" rel="me noopener noreferrer">
                    /arif-rachim ↗
                </a>
            </div>
        </div>
    </div>
</Page>

<style>
    .cta {
        background: var(--ink);
        color: var(--bg);
        border-radius: var(--radius-lg);
        padding: clamp(2rem, 5vw, 4rem);
        position: relative;
        overflow: hidden;
        box-shadow: var(--shadow-lg);
    }

    .cta::before {
        content: "";
        position: absolute;
        top: -40%;
        right: -20%;
        width: 560px;
        height: 560px;
        background: radial-gradient(circle, rgba(255, 91, 46, 0.35), transparent 60%);
        pointer-events: none;
    }

    .cta::after {
        content: "";
        position: absolute;
        bottom: -40%;
        left: -20%;
        width: 440px;
        height: 440px;
        background: radial-gradient(circle, rgba(255, 91, 46, 0.12), transparent 60%);
        pointer-events: none;
    }

    .cta-head {
        position: relative;
        max-width: 640px;
        margin-bottom: 2rem;
    }

    .title {
        font-size: var(--fs-2xl);
        font-weight: 600;
        line-height: 1.1;
        letter-spacing: -0.025em;
        margin-bottom: 0.75rem;
    }

    .subtitle {
        font-size: var(--fs-base);
        color: rgba(255, 255, 255, 0.65);
        line-height: 1.6;
    }

    .actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        margin-bottom: 2.5rem;
        position: relative;
    }

    .btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.9rem 1.5rem;
        border-radius: 999px;
        font-weight: 600;
        font-size: var(--fs-sm);
        text-decoration: none;
        transition: transform 0.2s ease, background 0.2s ease, color 0.2s ease;
    }

    .btn-primary {
        background: var(--accent);
        color: var(--accent-ink);
    }

    .btn-primary:hover {
        transform: translateY(-2px);
        background: #ff6f46;
    }

    .btn-ghost {
        background: transparent;
        color: var(--bg);
        border: 1px solid rgba(255, 255, 255, 0.25);
    }

    .btn-ghost:hover {
        background: rgba(255, 255, 255, 0.08);
        transform: translateY(-2px);
    }

    .info-grid {
        position: relative;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 1.25rem 2rem;
        padding-top: 2rem;
        border-top: 1px solid rgba(255, 255, 255, 0.12);
    }

    .info {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .label {
        font-family: "JetBrains Mono", ui-monospace, monospace;
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: rgba(255, 255, 255, 0.5);
    }

    .value {
        font-size: var(--fs-sm);
        font-weight: 500;
        color: var(--bg);
    }

    .link {
        text-decoration: none;
        color: var(--accent);
    }

    .link:hover {
        color: #ff8a5c;
    }
</style>
