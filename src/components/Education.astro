---
import Page from "./Page.astro";

const certifications: {
    name: string;
    organization: string;
    issued: string;
    url: string;
    description: string;
}[] = [
    {
        name: "Neo4j Certified Professional",
        organization: "Neo4j",
        issued: "April 2026",
        url: "https://graphacademy.neo4j.com/c/9dcbd270-8acb-4c18-a1e2-00ac43632afb/",
        description:
            "Completed the Neo4j GraphAcademy professional track covering graph data modeling, Cypher query optimization, and applied graph solutions for complex relationship and logistics problems.",
    },
    {
        name: "AI TensorFlow Developer Specialization",
        organization: "DeepLearning.AI",
        issued: "October 2020",
        url: "https://www.coursera.org/account/accomplishments/professional-cert/K7MXS6ZDJF55",
        description:
            "Completed all four courses in the DeepLearning.AI TensorFlow Developer Professional Certificate: building & training neural networks, CNNs for image recognition, NLP systems, and other essential TensorFlow concepts.",
    },
    {
        name: "Certified Arduino Fundamental",
        issued: "February 2020",
        url: "https://drive.google.com/file/d/12bJu4pl11P2YkUq3itGHuhMncNZZg8J2/view",
        organization: "Arduino",
        description:
            "Official Arduino certification covering electronics, programming and physical computing fundamentals.",
    },
    {
        name: "API Management Concepts",
        issued: "March 2018",
        url: "https://www.credly.com/badges/1fc4b1dd-4498-4b20-a814-a94892b7955e/linked_in_profile",
        organization: "IBM",
        description:
            "Demonstrates an understanding of business and architectural concepts of API development.",
    },
    {
        name: "Architecting Google Compute Engine",
        issued: "March 2018",
        url: "https://www.coursera.org/account/accomplishments/specialization/H8B9NDMLL94X",
        organization: "Coursera",
        description:
            "Specialization covering the design and deployment of solutions on Google Cloud Platform — networks, systems, and application services.",
    },
    {
        name: "Google Mobile Web Specialist",
        issued: "March 2018",
        url: "https://www.credential.net/9c990a3b-d9ea-4cfb-87f0-adedc97d366d?key=4bc0067199009ca60752c325bf03930e21091bcfeb38d4994e0fb68b57fe0066",
        organization: "Google",
        description:
            "Performance-based certification evaluating expertise in developing superior mobile web experiences: layout, networking, accessibility, PWAs, performance, caching, security, testing & JS design principles.",
    },
    {
        name: "Advanced CSS Concepts",
        issued: "February 2018",
        url: "https://courses.edx.org/certificates/43312906e0fa4d10ba53a03cba5d9aa3",
        organization: "Microsoft",
        description:
            "DEV218x on edX: Flexbox, CSS Grid, responsive design, Sass/SCSS, SVG, and web development tooling.",
    },
    {
        name: "Microservices Practitioner Essentials",
        issued: "March 2018",
        url: "https://www.credly.com/badges/118f3f5a-9ed3-4d6b-b900-78489df6c14b/linked_in_profile",
        organization: "IBM",
        description:
            "Knowledge of microservices architecture, refactoring, and developing applications with microservices frameworks.",
    },
    {
        name: "Docker Essentials",
        issued: "February 2018",
        url: "https://www.credly.com/badges/641bc0e2-4b27-4473-854b-ba35026f9e4f/linked_in_profile",
        organization: "IBM",
        description:
            "Running containers from Docker Hub, creating containers, orchestration (scaling, HA, service discovery), and Dockerfile best practices.",
    },
    {
        name: "IBM Blockchain Foundation Developer",
        issued: "January 2018",
        url: "https://www.credly.com/badges/da52b331-f6df-4407-8a9a-91e6bfe98d74/linked_in_profile",
        organization: "IBM",
        description:
            "Blockchain concepts: smart contracts, ledgers, business networks, participants, and Hyperledger Composer.",
    },
    {
        name: "Python for Data Science",
        issued: "January 2018",
        url: "https://www.credly.com/badges/0199436b-5cbb-4550-8638-e4d600ea7aaa/linked_in_profile",
        organization: "IBM",
        description:
            "Creating Python scripts and conducting fundamental hands-on data analysis within IBM's Jupyter-based lab environment.",
    },
    {
        name: "Sun Certified Programmer for Java 2 Platform",
        issued: "September 2007",
        url: "https://drive.google.com/file/d/1o57qOczdp90yW9C6bkmomSGCnQUXMZX9/view",
        organization: "Sun Microsystems",
        description:
            "SCJP — proficiency in Java: writing, compiling, debugging and troubleshooting programs, covering OOP, collections, exceptions, I/O, multithreading, and more.",
    },
];
---

<Page id="education" eyebrow="Education & Certifications">
    <div class="header-row">
        <h2 class="title">Learning never stops.</h2>
        <p class="subtitle">
            Formal education and a continuous stream of industry certifications.
        </p>
    </div>

    <div class="edu-grid">
        <article class="edu-card">
            <div class="edu-year">2000 — 2004</div>
            <h3 class="edu-name">Bachelor of Electrical Engineering</h3>
            <div class="edu-org">University of Indonesia</div>
            <p class="edu-desc">
                Major in Computer Engineering. Final Project: Distance Learning
                System with J2EE.
            </p>
        </article>
        <article class="edu-card">
            <div class="edu-year">1997 — 2000</div>
            <h3 class="edu-name">High School Diploma</h3>
            <div class="edu-org">SMA Negeri 8, Jakarta</div>
        </article>
    </div>

    <div class="sub-head">
        <h3 class="sub-title">Certifications</h3>
        <span class="count">{certifications.length} credentials</span>
    </div>

    <div class="cert-grid">
        {certifications.map((c) => (
            <a href={c.url} target="_blank" rel="noopener noreferrer" class="cert-card" aria-label={c.name}>
                <div class="cert-top">
                    <span class="cert-org">{c.organization}</span>
                    <span class="cert-date">{c.issued}</span>
                </div>
                <h4 class="cert-name">{c.name}</h4>
                <p class="cert-desc">{c.description}</p>
                <span class="cert-link">
                    View credential
                    <span aria-hidden="true">↗</span>
                </span>
            </a>
        ))}
    </div>
</Page>

<style>
    .header-row {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        margin-bottom: clamp(2rem, 4vw, 3rem);
    }

    .title {
        font-size: var(--fs-2xl);
        font-weight: 600;
        line-height: 1.1;
        letter-spacing: -0.025em;
    }

    .subtitle {
        font-size: var(--fs-base);
        color: var(--muted);
    }

    .edu-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1rem;
        margin-bottom: clamp(3rem, 6vw, 5rem);
    }

    .edu-card {
        background: var(--bg-elev);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
        transition: transform 0.25s ease, box-shadow 0.25s ease;
    }

    .edu-card:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow);
    }

    .edu-year {
        font-family: "JetBrains Mono", ui-monospace, monospace;
        font-size: 0.72rem;
        letter-spacing: 0.08em;
        color: var(--accent);
        font-weight: 500;
    }

    .edu-name {
        font-size: var(--fs-md);
        font-weight: 600;
        line-height: 1.3;
    }

    .edu-org {
        font-size: var(--fs-sm);
        color: var(--muted);
        font-weight: 500;
    }

    .edu-desc {
        font-size: var(--fs-sm);
        color: var(--muted);
        margin-top: 0.3rem;
    }

    .sub-head {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .sub-title {
        font-size: var(--fs-lg);
        font-weight: 600;
        letter-spacing: -0.015em;
    }

    .count {
        font-family: "JetBrains Mono", ui-monospace, monospace;
        font-size: 0.75rem;
        color: var(--muted);
    }

    .cert-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 1rem;
    }

    .cert-card {
        display: flex;
        flex-direction: column;
        gap: 0.55rem;
        background: var(--bg-elev);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 1.25rem 1.35rem;
        text-decoration: none;
        color: inherit;
        transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
        position: relative;
        overflow: hidden;
    }

    .cert-card::before {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, rgba(255, 91, 46, 0.06), transparent 50%);
        opacity: 0;
        transition: opacity 0.3s ease;
        pointer-events: none;
    }

    .cert-card:hover {
        transform: translateY(-3px);
        box-shadow: var(--shadow);
        border-color: var(--border-strong);
    }

    .cert-card:hover::before {
        opacity: 1;
    }

    .cert-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 0.5rem;
    }

    .cert-org {
        font-size: var(--fs-xs);
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--ink-2);
    }

    .cert-date {
        font-family: "JetBrains Mono", ui-monospace, monospace;
        font-size: 0.7rem;
        color: var(--muted);
    }

    .cert-name {
        font-size: var(--fs-md);
        font-weight: 600;
        line-height: 1.3;
        letter-spacing: -0.01em;
    }

    .cert-desc {
        font-size: var(--fs-sm);
        color: var(--muted);
        line-height: 1.55;
        flex: 1;
    }

    .cert-link {
        font-size: var(--fs-xs);
        font-weight: 600;
        color: var(--accent);
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        margin-top: 0.25rem;
    }

    @media (max-width: 620px) {
        .edu-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
