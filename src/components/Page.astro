---
interface Props {
    id?: string;
    eyebrow?: string;
    size?: "default" | "wide";
    reveal?: boolean;
}

const {id, eyebrow, size = "default", reveal = true} = Astro.props;
---

<section id={id} class:list={["section", size]} data-reveal={reveal ? "" : undefined}>
    <div class="section-inner">
        {eyebrow && (
            <div class="eyebrow">
                <span class="eyebrow-dash"></span>
                <span>{eyebrow}</span>
            </div>
        )}
        <slot/>
    </div>
</section>

<style>
    .section {
        width: 100%;
        padding: clamp(3rem, 6vw, 6rem) max(1rem, 5vw);
    }

    .section-inner {
        width: min(1280px, 100%);
        margin: 0 auto;
    }

    .section.wide .section-inner {
        width: min(1440px, 100%);
    }

    .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
        font-family: "JetBrains Mono", ui-monospace, monospace;
        font-size: 0.75rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 1.25rem;
    }

    .eyebrow-dash {
        width: 28px;
        height: 1px;
        background: var(--accent);
    }
</style>
